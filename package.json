{
  "name": "@nathapp/nax",
  "version": "0.5.0",
  "description": "AI Coding Agent Orchestrator — loops until done",
  "type": "module",
  "bin": {
    "nax": "./bin/nax.ts"
  },
  "scripts": {
    "dev": "bun run bin/nax.ts",
    "build": "bun build bin/nax.ts --outdir dist --target bun",
    "typecheck": "bun x tsc --noEmit",
    "lint": "bun x biome check src/ bin/",
    "test": "bun test --timeout=120000",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@types/react": "^19.2.14",
    "chalk": "^5.6.2",
    "commander": "^13.1.0",
    "ink": "^6.7.0",
    "ink-testing-library": "^4.0.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.2.4",
    "typescript": "^5.7.3"
  },
  "license": "MIT",
  "author": "William Khoo",
  "keywords": ["ai", "agent", "orchestrator", "tdd", "coding"]
}
