{
  "name": "@nathapp/nax",
  "version": "0.64.0-canary.9",
  "description": "AI Coding Agent Orchestrator — loops until done",
  "type": "module",
  "bin": {
    "nax": "./dist/nax.js"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "dev": "bun run bin/nax.ts",
    "build": "bun build bin/nax.ts --outdir dist --target bun --define \"GIT_COMMIT=\\\"$(git rev-parse --short HEAD)\\\"\"",
    "typecheck": "bun x tsc --noEmit",
    "lint": "bun x biome check src/ bin/",
    "lint:fix": "bun x biome check --write src/ bin/",
    "release": "bun scripts/release.ts",
    "test": "bun run scripts/run-tests.ts",
    "test:bail": "bun run scripts/run-tests.ts --bail",
    "test:no-wrap": "bun test test/unit/ --timeout=5000 && bun test test/integration/ --timeout=5000 && bun test test/ui/ --timeout=5000",
    "test:watch": "bun test --watch",
    "test:unit": "bun test ./test/unit/ --timeout=60000",
    "test:integration": "bun test ./test/integration/ --timeout=60000",
    "test:ui": "bun test ./test/ui/ --timeout=60000",
    "check-test-overlap": "bun run scripts/check-test-overlap.ts",
    "check-dead-tests": "bun run scripts/check-dead-tests.ts",
    "check:test-sizes": "bun run scripts/check-test-sizes.ts",
    "check:test-mocks": "bun scripts/check-inline-test-mocks.ts --strict",
    "check:process-cwd": "bash scripts/check-process-cwd.sh",
    "check:no-adapter-wrap": "bash scripts/check-no-adapter-wrap.sh",
    "check:dispatch-context": "bash scripts/check-dispatch-context.sh",
    "prepublishOnly": "bun run build",
    "test:full": "FULL=1 NAX_PRECHECK=1 bun test test/ --timeout=60000"
  },
  "dependencies": {
    "@types/react": "^19.2.14",
    "chalk": "^5.6.2",
    "commander": "^13.1.0",
    "ink": "^6.7.0",
    "ink-spinner": "^5.0.0",
    "ink-testing-library": "^4.0.0",
    "react": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.3.8",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5.7.3"
  },
  "license": "MIT",
  "author": "William Khoo",
  "keywords": [
    "ai",
    "agent",
    "orchestrator",
    "tdd",
    "coding"
  ],
  "files": [
    "dist/",
    "README.md",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nathapp-io/nax.git"
  },
  "homepage": "https://github.com/nathapp-io/nax",
  "bugs": {
    "url": "https://github.com/nathapp-io/nax/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  }
}
