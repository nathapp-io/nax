{
    "version": 1,
    "models": {
        "claude": {
            "fast": "haiku",
            "balanced": "sonnet",
            "powerful": "sonnet"
        },
        "opencode": {
            "fast": "minimax/MiniMax-M2.7",
            "balanced": "minimax/MiniMax-M2.7",
            "powerful": "minimax/MiniMax-M2.7"
        }
    },
    "autoMode": {
        "enabled": true,
        "defaultAgent": "opencode",
        "fallbackOrder": ["opencode"],
        "complexityRouting": {
            "simple": "fast",
            "medium": "balanced",
            "complex": "balanced",
            "expert": "powerful"
        },
        "escalation": {
            "enabled": true,
            "tierOrder": [
                {
                    "tier": "fast",
                    "attempts": 3
                },
                {
                    "tier": "balanced",
                    "attempts": 2
                },
                {
                    "tier": "powerful",
                    "attempts": 1
                }
            ],
            "escalateEntireBatch": false
        }
    },
    "generate": {
        "agents": ["claude", "codex", "gemini", "opencode"]
    },
    "agent": {
        "protocol": "acp"
    },
    "execution": {
        "permissionProfile": "unrestricted",
        "maxIterations": 6,
        "iterationDelayMs": 2000,
        "costLimit": 30.0,
        "sessionTimeoutSeconds": 7200,
        "verificationTimeoutSeconds": 600,
        "maxStoriesPerFeature": 15,
        "rectification": {
            "enabled": true,
            "maxRetries": 3,
            "rethinkAtAttempt": 2,
            "urgencyAtAttempt": 3,
            "fullSuiteTimeoutSeconds": 600,
            "maxFailureSummaryChars": 2000,
            "abortOnIncreasingFailures": true
        },
        "regressionGate": {
            "enabled": true,
            "mode": "deferred",
            "timeoutSeconds": 600,
            "acceptOnTimeout": true,
            "maxRectificationAttempts": 2
        }
    },
    "quality": {
        "requireTypecheck": true,
        "requireLint": true,
        "requireTests": true,
        "commands": {
            "test": "bun run test",
            "typecheck": "bun run typecheck",
            "lint": "bun run lint",
            "build": "bun run build",
            "testScoped": "CI=1 bun test --timeout=60000 {{files}}"
        },
        "forceExit": false,
        "detectOpenHandles": true,
        "detectOpenHandlesRetries": 1,
        "gracePeriodMs": 5000,
        "drainTimeoutMs": 2000
    },
    "debate": {
        "enabled": true,
        "agents": 2,
        "stages": {
            "plan": {
                "enabled": true,
                "rounds": 2,
                "sessionMode": "stateful",
                "resolver": {
                    "type": "synthesis",
                    "agent": "claude"
                },
                "debaters": [
                    {
                        "agent": "opencode",
                        "model": "fast"
                    },
                    {
                        "agent": "opencode",
                        "model": "fast"
                    }
                ]
            },
            "review": {
                "enabled": true,
                "rounds": 2,
                "sessionMode": "one-shot",
                "resolver": {
                    "type": "majority-fail-closed",
                    "agent": "claude",
                    "model": "fast"
                },
                "debaters": [
                    {
                        "agent": "opencode",
                        "model": "fast"
                    },
                    {
                        "agent": "opencode",
                        "model": "fast"
                    }
                ]
            },
            "acceptance": {
                "enabled": false,
                "rounds": 1,
                "sessionMode": "one-shot",
                "resolver": {
                    "type": "majority-fail-closed"
                }
            },
            "rectification": {
                "enabled": false,
                "rounds": 1,
                "sessionMode": "one-shot",
                "resolver": {
                    "type": "majority-fail-closed"
                }
            },
            "escalation": {
                "enabled": false,
                "rounds": 1,
                "sessionMode": "one-shot",
                "resolver": {
                    "type": "majority-fail-closed"
                }
            }
        }
    },
    "review": {
        "enabled": true,
        "checks": ["build", "typecheck", "lint", "semantic"],
        "commands": {
            "typecheck": "bun run typecheck",
            "lint": "bun run lint",
            "build": "bun run build",
            "lintFix": "bun run lint:fix",
            "formatFix": "bun run lint:fix"
        },
        "pluginMode": "deferred",
        "semantic": {
            "modelTier": "fast",
            "rules": []
        }
    },
    "plan": {
        "model": "balanced"
    }
}
