{
    "version": 1,
    "models": {
        "claude": {
            "fast": "haiku",
            "balanced": "sonnet",
            "powerful": "opus"
        },
        "opencode": {
            "fast": "minimax/MiniMax-M2.7",
            "balanced": "minimax/MiniMax-M2.7",
            "powerful": "minimax/MiniMax-M2.7"            
        }        
    },
    "autoMode": {
        "enabled": true,
        "defaultAgent": "claude",
        "fallbackOrder": ["claude"],
        "complexityRouting": {
            "simple": "fast",
            "medium": "balanced",
            "complex": "balanced",
            "expert": "powerful"
        },
        "escalation": {
            "enabled": true,
            "tierOrder": [
                {
                    "tier": "fast",
                    "attempts": 3
                },
                {
                    "tier": "balanced",
                    "attempts": 2
                },
                {
                    "tier": "powerful",
                    "attempts": 1
                }
            ],
            "escalateEntireBatch": false
        }
    },
    "generate": {
        "agents": ["claude", "codex", "gemini", "opencode"]
    },
    "agent": {
        "protocol": "acp"
    },
    "routing": {
        "strategy": "llm",
        "llm": {
            "model": "fast",
            "fallbackToKeywords": true,
            "cacheDecisions": true,
            "mode": "hybrid",
            "timeoutMs": 60000
        }
    },
    "execution": {
        "permissionProfile": "unrestricted",
        "maxIterations": 6,
        "iterationDelayMs": 2000,
        "costLimit": 30.0,
        "sessionTimeoutSeconds": 7200,
        "verificationTimeoutSeconds": 600,
        "maxStoriesPerFeature": 15,
        "rectification": {
            "enabled": true,
            "maxRetries": 2,
            "fullSuiteTimeoutSeconds": 600,
            "maxFailureSummaryChars": 2000,
            "abortOnIncreasingFailures": true
        },
        "regressionGate": {
            "enabled": true,
            "mode": "deferred",
            "timeoutSeconds": 600,
            "acceptOnTimeout": true,
            "maxRectificationAttempts": 2
        }
    },
    "quality": {
        "requireTypecheck": true,
        "requireLint": true,
        "requireTests": true,
        "commands": {
            "test": "bun run test",
            "typecheck": "bun run typecheck",
            "lint": "bun run lint",
            "build": "bun run build",
            "testScoped": "CI=1 bun test --timeout=60000 {{files}}"
        },
        "forceExit": false,
        "detectOpenHandles": true,
        "detectOpenHandlesRetries": 1,
        "gracePeriodMs": 5000,
        "drainTimeoutMs": 2000
    },
    "review": {
        "enabled": true,
        "checks": ["build", "typecheck", "lint", "semantic"],
        "commands": {
            "typecheck": "bun run typecheck",
            "lint": "bun run lint",
            "build": "bun run build",
            "lintFix": "bun run lint:fix",
            "formatFix": "bun run lint:fix"
        },
        "pluginMode": "deferred",
        "semantic": {
            "modelTier": "fast",
            "rules": []
        }
    },
    "plan": {
        "model": "powerful",
        "timeoutSeconds": 1200
    },
    "acceptance": {
        "model": "balanced"
    }
}
